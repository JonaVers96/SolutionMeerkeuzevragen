<Window x:Class="MeerkeuzevragenUI.LogInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeerkeuzevragenUI"
        mc:Ignorable="d"
        Title="LogInWindow" Height="450" Width="800">
    <StackPanel Margin="30" VerticalAlignment="Center">
        <TextBlock Text="Welkom! Voer je naam in:" Margin="0,0,0,10" FontWeight="Bold"/>
        <TextBox x:Name="txtNaam" Height="30" Margin="0,0,0,20" VerticalContentAlignment="Center"/>
        <Button Content="Inloggen" Height="35" Click="BtnLogin_Click" Background="#2196F3" Foreground="White"/>
    </StackPanel>
</Window>
